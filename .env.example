# =========================
# Backend (.env)
# =========================

# Core runtime
ENV=dev
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000
APP_TIMEZONE=UTC

# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/salma_school

# Redis (OTP / revoke / rate limit helpers)
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=
REDIS_SSL=false
AUTH_FAIL_CLOSED=false

# Auth / JWT
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_AUDIENCE=voice-agent
JWT_ISSUER=http://localhost:8000
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
DISABLE_OTP=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQ=60
WIDGET_PUBLIC_TOKEN=
ENABLE_DEV_ENDPOINTS=false

# Tenant scope / fail-closed
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
ENFORCE_TENANT_SCOPE=true
TENANT_PUBLIC_PATHS=/health,/health/ready,/health/live,/auth/login,/auth/verify-otp,/auth/refresh,/chat/chat,/chat/message,/sms/incoming,/whatsapp/incoming,/webhooks/meta/whatsapp,/email/incoming,/voice/token,/voice/outbound,/voice/incoming,/voice/recording-status,/events/call-status,/school/public,/school/contact-requests,/uploads
TENANT_FAIL_CLOSED_PUBLIC_PATHS=/sms/incoming,/whatsapp/incoming,/webhooks/meta/whatsapp,/email/incoming,/voice/incoming,/voice/recording-status,/events/call-status,/chat/chat,/chat/message,/voice/token,/voice/outbound,/school/contact-requests
# provider_key / tenant_token publics sont stockes en base (table tenant_channels), pas en env.

# LLM / STT / TTS
OPENAI_API_KEY=
GPT5_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
STT_LANGUAGE=multi
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Twilio (SMS + Voice + WhatsApp via Twilio)
SMS_PROVIDER=twilio
WHATSAPP_PROVIDER=meta
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VOICE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_REGION=ie1

# Meta WhatsApp Cloud API (si WHATSAPP_PROVIDER=meta)
META_API_VERSION=v20.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=

# Orange SMS (si SMS_PROVIDER=orange)
ORANGE_SMS_CLIENT_ID=
ORANGE_SMS_CLIENT_SECRET=
ORANGE_SMS_SENDER_NUMBER=

# Email / SMTP
EMAIL_PROVIDER=brevo
MAIL_MAILER=brevo
FROM_EMAIL=no-reply@example.com
FROM_NAME=Salma School
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Salma School
BREVO_API_KEY=
SENDGRID_API_KEY=
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# Inbound webhooks
WEBHOOK_REPLAY_TTL_SEC=300
WEBHOOK_FAIL_CLOSED=true
EMAIL_WEBHOOK_SECRET=
EMAIL_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
EMAIL_WEBHOOK_IP_ALLOWLIST=
MAILGUN_WEBHOOK_SIGNING_KEY=

# Google Calendar
GOOGLE_CREDENTIALS_JSON_BASE64=
GOOGLE_CALENDAR_ID=

# Encryption / secrets
KMS_KEY_ID=
APP_ENCRYPTION_KEY_BASE64=
ALLOW_EPHEMERAL_ENCRYPTION_KEY=false

# Login hardening
AUTH_RATE_LIMIT_WINDOW_SEC=600
AUTH_RATE_LIMIT_IP_MAX=30
AUTH_RATE_LIMIT_IDENTIFIER_MAX=10
AUTH_LOCK_THRESHOLD=5
AUTH_LOCK_BASE_SEC=60
AUTH_LOCK_MAX_SEC=3600
AUTH_JITTER_MIN_MS=220
AUTH_JITTER_MAX_MS=380
AUTH_SECURITY_FAIL_CLOSED=false

# KPI / outbox
SMS_UNIT_COST=0
EMAIL_UNIT_COST=0
OUTBOX_MODE_ENABLED=false
OUTBOX_BATCH_SIZE=50
OUTBOX_RETRY_BASE_SEC=30

# Monitoring / alerting
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
ADMIN_ALERT_EMAIL=
ALERT_FAILED_LOGINS_THRESHOLD=8
ALERT_FAILED_LOGINS_WINDOW_MIN=30
ALERT_DEDUPE_TTL_SEC=900

# =========================
# Frontend dashboard (.env in front/dashboard)
# =========================
VITE_API_BASE=http://localhost:8000
VITE_API_TOKEN=
VITE_DISABLE_OTP=false
VITE_WIDGET_TOKEN=
VITE_SENTRY_DSN=
VITE_ENV=development

# =========================
# Tests / scripts (optional)
# =========================
# Stripe billing (optional - required for paid plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# =========================
# Tests / scripts (optional)
# =========================
E2E_BASE_URL=http://localhost:4173
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
